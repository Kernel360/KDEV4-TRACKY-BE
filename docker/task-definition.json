{
  "family": "tracky-task",
  "networkMode": "awsvpc",
  "requiresCompatibilities": ["FARGATE"],
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::634915147069:role/ecsTaskExecutionRole",
  "containerDefinitions": [
    {
      "name": "tracky-container",
      "image": "634915147069.dkr.ecr.ap-northeast-2.amazonaws.com/tracky-docker:latest",
      "memory": 512,
      "cpu": 256,
      "essential": true,
      "portMappings": [
        {
          "containerPort": 80,
          "hostPort": 80,
          "protocol": "tcp"
        }
      ]
    }
  ]
}
